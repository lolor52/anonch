  "pairNotes": {
    "ENFP:INTJ": {
      "tone": "strong",
      "text": "Один приносит живость и новые связи, другой — структуру и дальний горизонт."
    },
    "ENFP:INFJ": {
      "tone": "strong",
      "text": "Тёплая эмпатия здесь сочетается с идеями и ощущением смысла."
    },
    "ENTP:INFJ": {
      "tone": "strong",
      "text": "Один раскачивает новые версии, второй удерживает глубину и направление."
    },
    "ENTP:INTJ": {
      "tone": "strong",
      "text": "Спор идей быстро превращается в рабочую стратегию."
    },
    "ENFJ:INTP": {
      "tone": "strong",
      "text": "Логика и человеческое чутьё хорошо дополняют друг друга."
    },
    "ENFJ:INFP": {
      "tone": "strong",
      "text": "Общие ценности помогают держать близость без лишней жёсткости."
    },
    "ENTJ:INFP": {
      "tone": "strong",
      "text": "Один задаёт темп, второй не даёт потерять смысл по дороге."
    },
    "ENTJ:INTP": {
      "tone": "strong",
      "text": "Сильная связка идей, структуры и интеллектуального уважения."
    },
    "ESFP:ISTJ": {
      "tone": "strong",
      "text": "Стабильность встречается с живостью, и пара не застывает."
    },
    "ESFP:ISFJ": {
      "tone": "strong",
      "text": "Тепло, забота и лёгкость контакта быстро создают комфорт."
    },
    "ESTP:ISFJ": {
      "tone": "strong",
      "text": "Один приносит смелость, второй — мягкую надёжность."
    },
    "ESTP:ISTJ": {
      "tone": "strong",
      "text": "Практичность и скорость дают рабочий баланс."
    },
    "ESFJ:ISTP": {
      "tone": "strong",
      "text": "Один чинит и действует, второй удерживает людей и договорённости."
    },
    "ESFJ:ISFP": {
      "tone": "strong",
      "text": "Тепло и такт помогают обходить острые углы без лишнего давления."
    },
    "ESTJ:ISFP": {
      "tone": "strong",
      "text": "Один собирает рамку, второй добавляет вкус и человечность."
    },
    "ESTJ:ISTP": {
      "tone": "strong",
      "text": "Решения быстро переходят в действие, если роли понятны."
    },
    "ESFP:INTJ": {
      "tone": "difficult",
      "text": "Один хочет долгую стратегию, второй живёт моментом; ритм быстро расходится."
    },
    "ESFJ:INTJ": {
      "tone": "difficult",
      "text": "Логическая сухость одного и социальная чувствительность другого легко ранят."
    },
    "ESFP:INTP": {
      "tone": "difficult",
      "text": "Спонтанность и абстрактность часто не совпадают по темпу и ожиданиям."
    },
    "ESFJ:INTP": {
      "tone": "difficult",
      "text": "Один ждёт ясной логики, другой — явного участия и тепла."
    },
    "ENTJ:ISFP": {
      "tone": "difficult",
      "text": "Прямой нажим одного быстро задевает внутреннюю чувствительность другого."
    },
    "ENTJ:ESTP": {
      "tone": "difficult",
      "text": "Оба быстрые, но один хочет контролировать, а второй — проверять границы."
    },
    "INFJ:ISFP": {
      "tone": "difficult",
      "text": "Один ищет скрытый смысл, другой держится чувства момента; им трудно синхронизироваться в долгом плане."
    },
    "ESTP:INFJ": {
      "tone": "difficult",
      "text": "Внешний темп и внутренняя глубина часто не совпадают по способу решения."
    },
    "ENTP:ISFJ": {
      "tone": "difficult",
      "text": "Один ломает рамки, другой держится проверенного, и усталость растёт слишком быстро."
    },
    "ENTP:ESTJ": {
      "tone": "difficult",
      "text": "Один любит открытые варианты, другой хочет закрыть вопрос и идти по плану."
    },
    "INFP:ISFJ": {
      "tone": "difficult",
      "text": "Один уходит в внутренний поиск, другой ждёт более конкретной взаимности и быта."
    },
    "ESTJ:INFP": {
      "tone": "difficult",
      "text": "Правила и внутренняя свобода часто сталкиваются лоб в лоб."
    },
    "ENFJ:ISTP": {
      "tone": "difficult",
      "text": "Один хочет проговаривать чувства, другой предпочитает молча чинить проблему."
    },
    "ENFJ:ISTJ": {
      "tone": "difficult",
      "text": "Один ведёт через отношения, другой — через правило; обоим трудно признать чужой темп."
    },
    "ENFP:ISTP": {
      "tone": "difficult",
      "text": "Эмоциональная экспрессия одного и сдержанность другого быстро создают шум."
    },
    "ENFP:ISTJ": {
      "tone": "difficult",
      "text": "Свобода и жёсткий порядок легко входят в прямой конфликт."
    }
  },
