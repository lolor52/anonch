{
  "name": "anonch",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "http-server . -p 4173 -c-1 --silent",
    "start": "npm run dev",
    "serve": "npm run dev",
    "test:unit": "node --test tests/unit/auth-manager.test.mjs tests/unit/provider-adapters.test.mjs tests/unit/mbti-engine.test.mjs tests/unit/mbti-service.test.mjs",
    "test:data": "python3 tests/unit/check_data_layer.py",
    "test:ui": "python3 tests/unit/check_static_ui.py",
    "test": "npm run test:unit && npm run test:data && npm run test:ui",
    "e2e": "playwright test",
    "visual": "node tools/run-visual-check.mjs",
    "check": "npm run test && npm run e2e && npm run visual",
    "check:auth": "node --test tests/unit/auth-manager.test.mjs tests/unit/provider-adapters.test.mjs",
    "check:mbti": "node --test tests/unit/mbti-engine.test.mjs tests/unit/mbti-service.test.mjs",
    "check:data": "python3 tests/unit/check_data_layer.py",
    "check:ui": "python3 tests/unit/check_static_ui.py",
    "check:visual": "npm run visual"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "http-server": "^14.1.1",
    "playwright": "^1.52.0"
  }
}
